{
  "name": "atlas",
  "version": "0.4.0",
  "description": "Consent-first, filesystem-native, multi-modal workspace intelligence assistant",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "ui:dev": "vite",
    "ui:build": "vite build",
    "ui:preview": "vite preview",
    "build": "vite build",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "latest",
    "@kenjiuno/msgreader": "latest",
    "@xenova/transformers": "latest",
    "chokidar": "^5.0.0",
    "cors": "latest",
    "dotenv": "latest",
    "express": "latest",
    "fluent-ffmpeg": "latest",
    "jszip": "latest",
    "mammoth": "latest",
    "nodemailer": "latest",
    "openai": "latest",
    "pdf-parse": "latest",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "uuid": "latest",
    "xlsx": "latest"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "jest": "^30.3.0",
    "nodemon": "latest",
    "vite": "^8.0.9"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "setupFiles": [
      "<rootDir>/tests/_setup_env.js"
    ],
    "maxWorkers": 1
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "license": "UNLICENSED"
}
